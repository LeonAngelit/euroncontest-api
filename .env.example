# EuronContest API — Environment Variables Example
#
# Copy this file to .env and fill in your actual values.
#
# IMPORTANT: AUTH_P must be a bcrypt-hashed string, NOT plain text.
# Generate a hash with:
#   npx bcrypt-cli hash "your-secret-password"
# or programmatically:
#   node -e "console.log(require('bcrypt').hashSync('your-secret-password', 12))"
#
# The server validates on startup that AUTH_P matches the pattern $2[aby]$NN$...
# and will refuse to start if it is missing or not a valid bcrypt hash.

AUTH_P="$2b$12$<your-bcrypt-hash-here>"
PORT="3020"
NODE_ENV="dev"

# PostgreSQL
DB_USER=""
DB_PASSWORD=""
DB_HOST=""
DB_NAME=""
DB_PORT=""
DATABASE_URL=""

# JWT
P_KEY=""

# Google OAuth / Drive
DRIVE_ID=""
DRIVE_SECRET=""
DRIVE_REFRESH=""

# Email
MAIL_SERVER=""
MAIL_PASS=""
USER_MAIL=""
CONFIRM_EMAIL_URL=""

# MongoDB
MONGO_USER=""
MONGO_PASS=""
MONGO_DOMAIN=""
MONGO_APP_NAME=""
MONGO_RS_NAME=""
MONGO_COLLECTION_NAME="Archive"
MONGO_COMFY_COLLECTION_NAME="Comfy"

# Cloudinary
IMAGES_CLOUD_NAME=""
IMAGES_API_KEY=""
IMAGES_API_SECRET=""

# Eurovision scraping
BASE_URL=""
URL_VIDEOS=""
FIRST_YEAR=""
FIRST_YEAR_SCRIPT=""

# ComfyUI
REQUESTS_ENDPOINT=""
